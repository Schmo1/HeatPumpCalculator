# Kopiere diese Datei nach ".env" und passe die Werte an.

# Signaturschlüssel für die JWT-Tokens – mindestens 32 Zeichen, geheim halten!
# Beispiel erzeugen: openssl rand -base64 48
JWT_KEY=bitte-einen-langen-zufaelligen-schluessel-mit-mind-32-zeichen-setzen

# Admin-Konto (darf Werte eintragen/ändern)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=bitte-aendern

# Leser-Konto (nur Ansicht)
READER_USERNAME=viewer
READER_PASSWORD=bitte-aendern

# Port, unter dem die Web-App erreichbar ist (http://localhost:PORT)
WEB_PORT=8080
