# Copy this file to ".env" and adjust the values.

# Signing key for the JWT tokens – at least 32 characters, keep it secret!
# Generate an example: openssl rand -base64 48
JWT_KEY=please-set-a-long-random-key-with-at-least-32-characters

# Admin account (may enter/edit values)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=please-change

# Reader account (view only)
READER_USERNAME=viewer
READER_PASSWORD=please-change

# Port on which the web app is reachable (http://localhost:PORT)
WEB_PORT=8080
